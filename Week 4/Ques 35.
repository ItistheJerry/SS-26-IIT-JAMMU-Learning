Q35_Weather_API.ino

#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <DHT.h>
#include "config.h"

#define DHT_PIN  4
#define DHT_TYPE DHT11

DHT dht(DHT_PIN, DHT_TYPE);

String buildURL() {

  return String("http://api.openweathermap.org/data/2.5/weather?q=")
       + CITY_NAME
       + "&appid=" + API_KEY
       + "&units=metric";

}

void setup() {

  Serial.begin(115200);
  delay(500);
  dht.begin();

  Serial.print("\nConnecting to Wi-Fi");
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {

    delay(500);
    Serial.print(".");

  }
  Serial.println("\nWi-Fi Connected! IP: " + WiFi.localIP().toString());

}

void loop() {

  float dhtTemp     = dht.readTemperature();
  float dhtHumidity = dht.readHumidity();

  if (isnan(dhtTemp) || isnan(dhtHumidity)) {

    Serial.println("[ERROR] Failed to read from DHT11 sensor!");
    delay(5000);
    return;

  }

  if (WiFi.status() != WL_CONNECTED) {

    Serial.println("[ERROR] Wi-Fi disconnected. Retrying...");
    WiFi.reconnect();
    delay(3000);
    return;

  }

  HTTPClient http;
  http.begin(buildURL());
  int httpCode = http.GET();

  if (httpCode != 200) {

    Serial.printf("[ERROR] HTTP GET failed. Code: %d\n", httpCode);
    http.end();
    delay(10000);
    return;

  }

  String payload = http.getString();
  http.end();

  StaticJsonDocument<1024> doc;
  DeserializationError error = deserializeJson(doc, payload);

  if (error) {

    Serial.println("[ERROR] JSON parsing failed: " + String(error.c_str()));
    delay(10000);
    return;

  }

  const char* cityName    = doc["name"];
  float apiTemp           = doc["main"]["temp"];
  float apiHumidity       = doc["main"]["humidity"];
  const char* description = doc["weather"][0]["description"];

  float tempDiff     = apiTemp - dhtTemp;
  float humidityDiff = apiHumidity - dhtHumidity;

  Serial.println("\nWEATHER DATA REPORT");
  Serial.printf("City          : %s\n", cityName);
  Serial.printf("Description   : %s\n", description);
  Serial.printf("API Temp      : %.1f C\n", apiTemp);
  Serial.printf("DHT11 Temp    : %.1f C\n", dhtTemp);
  Serial.printf("Difference    : %+.1f C\n", tempDiff);
  Serial.printf("API Humidity  : %.0f %%\n", apiHumidity);
  Serial.printf("DHT11 Humidity: %.0f %%\n", dhtHumidity);
  Serial.printf("Difference    : %+.0f %%\n", humidityDiff);

  delay(30000);

}

